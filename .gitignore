# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

/.vscode

# dependencies
/frontend/node_modules*

# backend
__pycache__/
**/__pycache__/
backend\*\__pycache__
*.pyc
*.pyo

# debug
/frontend/npm-debug.log*

# local env files - IMPORTANT: Never commit real credentials
.env
.env.local
.env.*.local
# Keep .env.example as it contains no secrets
!.env.example

# docker (keep docker-compose for version control if needed)
# docker-compose.yml

# Build outputs
/frontend/dist
/frontend/build

# IDE
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/